# === CAMPUSCONNECT ENVIRONMENT VARIABLES ===

# DATABASE (REQUIRED)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/campusconnect?schema=public"
# Get from: https://supabase.com (free tier) or https://neon.tech (free tier)
# Or use a local PostgreSQL instance

# NEXTAUTH (REQUIRED)
NEXTAUTH_URL="http://localhost:3000"
# In production: https://your-app.vercel.app
NEXTAUTH_SECRET="change-this-run-node-e-require-crypto-randomBytes-32-toString-hex"
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# GOOGLE OAUTH (REQUIRED for login)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
# Go to: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID (Web application)
# Add redirect URI: http://localhost:3000/api/auth/callback/google
# Copy Client ID & Client Secret here

# IMAGE STORAGE (optional - falls back to local /public/uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Get from: https://cloudinary.com (free tier available)

# SMS OTP (optional - dev code '123456' works without it)
SMS_API_KEY=""
SMS_API_SECRET=""
# Get from: https://twilio.com or https://msg91.com

# MAPS (NOT NEEDED - app uses Leaflet + OpenStreetMap, completely free)
# No API key required for maps!

# JWT (for Socket.io auth)
JWT_SECRET="change-this-too"

# ADMIN
ADMIN_EMAIL="admin@campusconnect.app"
# First user with this email gets admin role
